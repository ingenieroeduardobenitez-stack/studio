
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del catequista o administrador de la parroquia.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "allowedModules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Lista de IDs de módulos a los que el usuario tiene acceso."
        },
        "photoUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "ConfirmationRegistration": {
      "title": "Inscripción de Confirmación",
      "description": "Detalles completos del postulante a la confirmación.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "ciNumber": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "catechesisYear": {
          "type": "string",
          "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS"]
        },
        "attendanceDay": {
          "type": "string",
          "enum": ["SABADO", "DOMINGO"]
        },
        "attendanceStatus": {
          "type": "string",
          "enum": ["PRESENTE", "AUSENTE", "PENDIENTE"]
        },
        "needsRecovery": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["INSCRITO", "PENDIENTE", "OBSERVADO"]
        },
        "registrationCost": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Cedula": {
      "title": "Cédula de Identidad",
      "description": "Registro de identificación detallado para validación masiva.",
      "type": "object",
      "properties": {
        "NUMERO_CED": {
          "type": "string"
        },
        "APELLIDO": {
          "type": "string"
        },
        "NOMBRE": {
          "type": "string"
        },
        "SEXO": {
          "type": "string"
        },
        "NACIONAL": {
          "type": "string"
        },
        "NOM_PADRE": {
          "type": "string"
        },
        "NOM_MADRE": {
          "type": "string"
        },
        "DIRECCION": {
          "type": "string"
        },
        "NOM_CONJ": {
          "type": "string"
        },
        "FECHA_NACI": {
          "type": "string",
          "description": "Fecha de nacimiento en formato YYYY-MM-DD para compatibilidad con el sistema."
        },
        "BARRIO_CIU": {
          "type": "string"
        },
        "importedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["NUMERO_CED"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de los catequistas."
    },
    "/confirmations/{registrationId}": {
      "schema": "ConfirmationRegistration",
      "description": "Inscripciones detalladas."
    },
    "/groups/{groupId}": {
      "schema": "CatechesisGroup",
      "description": "Grupos de catequesis."
    },
    "/cedulas/{cedulaNumber}": {
      "schema": "Cedula",
      "description": "Base de datos masiva de cédulas importadas."
    }
  }
}
