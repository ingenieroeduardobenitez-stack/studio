
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del catequista o administrador de la parroquia.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "allowedModules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Lista de IDs de módulos a los que el usuario tiene acceso."
        },
        "photoUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "ConfirmationRegistration": {
      "title": "Inscripción de Confirmación",
      "description": "Detalles completos del postulante a la confirmación.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "paymentProofUrl": {
          "type": "string",
          "description": "Foto del comprobante de transferencia bancaria."
        },
        "ciNumber": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "motherName": { "type": "string" },
        "motherPhone": { "type": "string" },
        "fatherName": { "type": "string" },
        "fatherPhone": { "type": "string" },
        "tutorName": { "type": "string" },
        "tutorPhone": { "type": "string" },
        "catechesisYear": {
          "type": "string",
          "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS", "COMPLETADO"]
        },
        "attendanceDay": {
          "type": "string",
          "enum": ["SABADO", "DOMINGO"]
        },
        "groupId": {
          "type": "string",
          "description": "ID del grupo asignado."
        },
        "attendanceStatus": {
          "type": "string",
          "enum": ["PRESENTE", "AUSENTE", "PENDIENTE"]
        },
        "needsRecovery": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["INSCRITO", "PENDIENTE_PAGO", "POR_VALIDAR", "OBSERVADO", "ARCHIVADO"]
        },
        "registrationCost": {
          "type": "number"
        },
        "amountPaid": {
          "type": "number"
        },
        "paymentStatus": {
          "type": "string",
          "enum": ["PAGADO", "PENDIENTE", "PARCIAL"]
        },
        "isArchived": {
          "type": "boolean"
        },
        "archiveYear": {
          "type": "number"
        },
        "changeHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "oldGroupId": { "type": "string" },
              "newGroupId": { "type": "string" },
              "reason": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "authorizedBy": { "type": "string" }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Group": {
      "title": "Grupo de Catequesis",
      "description": "Agrupación de alumnos con sus respectivos catequistas.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "catequistaIds": { "type": "array", "items": { "type": "string" } },
        "attendanceDay": { "type": "string", "enum": ["SABADO", "DOMINGO"] },
        "catechesisYear": { "type": "string", "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS"] },
        "schedule": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TreasurySettings": {
      "title": "Configuración de Tesorería",
      "description": "Montos globales y datos bancarios definidos por el tesorero.",
      "type": "object",
      "properties": {
        "juvenileCost": { "type": "number" },
        "adultCost": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["ACCOUNT", "ALIAS"] },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountOwner": { "type": "string" },
        "ownerCi": { "type": "string" },
        "alias": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Event": {
      "title": "Evento Parroquial",
      "description": "Evento con costo asociado para cobro en tesorería.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cost": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de los catequistas."
    },
    "/confirmations/{registrationId}": {
      "schema": "ConfirmationRegistration",
      "description": "Inscripciones detalladas."
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Grupos de catequesis."
    },
    "/settings/treasury": {
      "schema": "TreasurySettings",
      "description": "Configuración de costos de inscripción y datos bancarios."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Eventos y jornadas configuradas."
    }
  }
}
