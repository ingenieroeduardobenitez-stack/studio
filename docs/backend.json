
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del catequista o administrador de la parroquia.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "ConfirmationRegistration": {
      "title": "Inscripción de Confirmación",
      "description": "Detalles completos del postulante a la confirmación.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "ciNumber": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "catechesisYear": {
          "type": "string",
          "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS"]
        },
        "attendanceDay": {
          "type": "string",
          "enum": ["SABADO", "DOMINGO"]
        },
        "attendanceStatus": {
          "type": "string",
          "enum": ["PRESENTE", "AUSENTE", "PENDIENTE"]
        },
        "needsRecovery": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["INSCRITO", "PENDIENTE", "OBSERVADO"]
        },
        "registrationCost": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Cedula": {
      "title": "Cédula de Identidad",
      "description": "Registro de identificación detallado para validación masiva.",
      "type": "object",
      "properties": {
        "number": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "sex": {
          "type": "string"
        },
        "nationality": {
          "type": "string"
        },
        "fatherName": {
          "type": "string"
        },
        "motherName": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "spouseName": {
          "type": "string"
        },
        "birthDate": {
          "type": "string"
        },
        "neighborhoodCity": {
          "type": "string"
        },
        "importedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["number"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de los catequistas."
    },
    "/confirmations/{registrationId}": {
      "schema": "ConfirmationRegistration",
      "description": "Inscripciones detalladas."
    },
    "/groups/{groupId}": {
      "schema": "CatechesisGroup",
      "description": "Grupos de catequesis."
    },
    "/cedulas/{cedulaNumber}": {
      "schema": "Cedula",
      "description": "Base de datos masiva de cédulas importadas basada en los campos NUMERO_CED, APELLIDO, NOMBRE, SEXO, NACIONAL, NOM_PADRE, NOM_MADRE, DIRECCION, NOM_CONJ, FECHA_NACI, BARRIO_CIU."
    }
  }
}
