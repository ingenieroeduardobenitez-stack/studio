
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del catequista o administrador de la parroquia.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "Nombre"
        },
        "lastName": {
          "type": "string",
          "description": "Apellido"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Correo electrónico"
        },
        "role": {
          "type": "string",
          "description": "Rol en la parroquia (Catequista, Administrador, etc.)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha de registro"
        }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "ConfirmationRegistration": {
      "title": "Inscripción de Confirmación",
      "description": "Detalles del postulante a la confirmación.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID del usuario que realiza la inscripción"
        },
        "fullName": {
          "type": "string",
          "description": "Nombre completo del postulante"
        },
        "age": {
          "type": "number",
          "description": "Edad del postulante"
        },
        "category": {
          "type": "string",
          "enum": ["JUVENIL", "ADULTO"],
          "description": "Categoría de la confirmación"
        },
        "baptized": {
          "type": "boolean",
          "description": "Si ya cuenta con el sacramento del Bautismo"
        },
        "firstCommunion": {
          "type": "boolean",
          "description": "Si ya cuenta con la Primera Comunión"
        },
        "notes": {
          "type": "string",
          "description": "Observaciones adicionales"
        },
        "status": {
          "type": "string",
          "enum": ["PENDIENTE", "INSCRITO", "OBSERVADO"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de los catequistas o encargados."
    },
    "/confirmations/{registrationId}": {
      "schema": "ConfirmationRegistration",
      "description": "Almacena las inscripciones a confirmación."
    }
  }
}
