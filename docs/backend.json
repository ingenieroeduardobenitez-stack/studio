{
  "entities": {
    "User": {
      "title": "User",
      "description": "Perfil del personal de la parroquia (catequistas, coordinadores, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Catequista", "Coordinador", "Tesorero", "Administrador"] },
        "photoUrl": { "type": "string", "format": "uri" },
        "allowedModules": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    },
    "Confirmation": {
      "title": "Confirmation",
      "description": "Registro de inscripción para el sacramento de la Confirmación",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "ciNumber": { "type": "string" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "photoUrl": { "type": "string", "format": "uri" },
        "catechesisYear": { "type": "string" },
        "attendanceDay": { "type": "string" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "amountPaid": { "type": "number" },
        "registrationCost": { "type": "number" },
        "paymentProofUrl": { "type": "string", "format": "uri" },
        "eventPayments": { "type": "object" }
      }
    },
    "Group": {
      "title": "Group",
      "description": "Grupo de catequesis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "catequistaIds": { "type": "array", "items": { "type": "string" } },
        "attendanceDay": { "type": "string" },
        "catechesisYear": { "type": "string" }
      }
    },
    "Event": {
      "title": "Event",
      "description": "Eventos especiales con costo (Retiros, Jornadas, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "cost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/confirmations/{confirmationId}",
        "definition": {
          "entityName": "Confirmation",
          "description": "Colección principal de inscritos",
          "params": [
            { "name": "confirmationId", "description": "ID del registro" }
          ]
        }
      },
      {
        "path": "/events/{eventId}",
        "definition": {
          "entityName": "Event",
          "description": "Eventos parroquiales con arancel",
          "params": [
            { "name": "eventId", "description": "ID del evento" }
          ]
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Perfiles de usuario",
          "params": [
            { "name": "userId", "description": "UID" }
          ]
        }
      }
    ]
  }
}
