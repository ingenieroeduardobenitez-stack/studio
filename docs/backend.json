
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del catequista o administrador de la parroquia.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "Nombre"
        },
        "lastName": {
          "type": "string",
          "description": "Apellido"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Correo electrónico"
        },
        "role": {
          "type": "string",
          "description": "Rol en la parroquia (Catequista, Coordinador, Administrador)"
        },
        "photoUrl": {
          "type": "string",
          "description": "URL o Base64 de la foto de perfil"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha de registro"
        }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "ConfirmationRegistration": {
      "title": "Inscripción de Confirmación",
      "description": "Detalles completos del postulante a la confirmación.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID del catequista que registra"
        },
        "fullName": {
          "type": "string",
          "description": "Nombre y Apellido del confirmando"
        },
        "photoUrl": {
          "type": "string",
          "description": "Foto del confirmando (Base64)"
        },
        "ciNumber": {
          "type": "string",
          "description": "Número de Cédula de Identidad"
        },
        "phone": {
          "type": "string",
          "description": "Número de celular del confirmando"
        },
        "motherName": {
          "type": "string"
        },
        "motherPhone": {
          "type": "string"
        },
        "fatherName": {
          "type": "string"
        },
        "fatherPhone": {
          "type": "string"
        },
        "tutorName": {
          "type": "string"
        },
        "tutorPhone": {
          "type": "string"
        },
        "catechesisYear": {
          "type": "string",
          "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS"],
          "description": "Año de Catequesis"
        },
        "attendanceDay": {
          "type": "string",
          "enum": ["SABADO", "DOMINGO"],
          "description": "Día de asistencia original"
        },
        "attendanceStatus": {
          "type": "string",
          "enum": ["PRESENTE", "AUSENTE", "PENDIENTE"],
          "description": "Estado de asistencia actual"
        },
        "needsRecovery": {
          "type": "boolean",
          "description": "Indica si debe recuperar en el día opuesto"
        },
        "hasBaptism": {
          "type": "boolean",
          "description": "Si ya recibió el Bautismo"
        },
        "hasFirstCommunion": {
          "type": "boolean",
          "description": "Si ya recibió la Primera Comunión"
        },
        "status": {
          "type": "string",
          "enum": ["INSCRITO", "PENDIENTE", "OBSERVADO"]
        },
        "registrationCost": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "CatechesisGroup": {
      "title": "Grupo de Catequesis",
      "description": "Define un grupo de trabajo compuesto por varios catequistas.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre del grupo"
        },
        "catequistaIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista de IDs de usuarios asignados al grupo"
        },
        "attendanceDay": {
          "type": "string",
          "enum": ["SABADO", "DOMINGO"],
          "description": "Día de la catequesis"
        },
        "catechesisYear": {
          "type": "string",
          "enum": ["PRIMER_AÑO", "SEGUNDO_AÑO", "ADULTOS"],
          "description": "Año de Catequesis"
        },
        "schedule": {
          "type": "string",
          "description": "Horario de la catequesis"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "catequistaIds", "attendanceDay", "catechesisYear"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de los catequistas o encargados."
    },
    "/confirmations/{registrationId}": {
      "schema": "ConfirmationRegistration",
      "description": "Almacena las inscripciones detalladas a confirmación."
    },
    "/groups/{groupId}": {
      "schema": "CatechesisGroup",
      "description": "Almacena los grupos de catequesis y sus miembros."
    }
  }
}
