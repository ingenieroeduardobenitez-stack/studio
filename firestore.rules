
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Un admin es alguien que tiene el rol explícito en su documento de usuario
    // o está en la colección roles_admin por compatibilidad
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Administrador"
      );
    }

    function isTesorero() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Tesorero";
    }

    // --- REGLAS DE COLECCIONES ---

    // Perfiles de usuario
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Inscripciones (Confirmaciones)
    match /confirmations/{id} {
      // Cualquier persona puede inscribirse (público)
      allow create: if true;
      // Solo personal autorizado puede ver y gestionar las listas
      allow read, update, delete: if isSignedIn();
    }

    // Grupos de catequesis
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Eventos especiales (Retiros, Jornadas, etc.)
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTesorero();
    }

    // Ajustes de tesorería y costos
    match /settings/{settingId} {
      allow read: if true; // Público para ver costos en el formulario
      allow write: if isAdmin() || isTesorero();
    }

    // Auditoría
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Consulta de cédulas (Importación)
    match /cedulas/{cedulaId} {
      allow get: if true; // Permitir búsqueda pública por C.I.
    }

    // Marcador de Administradores (DBAC)
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false;
    }

    // Compatibilidad con el blueprint antiguo
    match /catechesisSessions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
