
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Administrador";
    }

    function isTesorero() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Tesorero";
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isAdmin() || isTesorero();
    }

    match /confirmations/{id} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTesorero();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTesorero();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isTesorero();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isTesorero();
      allow create: if isSignedIn();
    }

    match /cedulas/{cedulaId} {
      allow get: if true;
    }
  }
}
