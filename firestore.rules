rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Administrador";
    }

    function isTesorero() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Tesorero";
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isAdmin() || isTesorero();
    }

    match /confirmations/{id} {
      // PERMISOS PÚBLICOS: Se permite crear y leer (para verificar duplicados por C.I.) a cualquier persona
      // v1.3.1 - Asegurando acceso para inscripción pública
      allow create, read: if true;
      
      // Solo personal autorizado puede modificar o borrar fichas
      allow update, delete: if isSignedIn();
      
      match /attendance/{atId} {
        allow read, write: if isSignedIn();
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTesorero();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTesorero();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      // Se permite lectura pública para que los postulantes vean aranceles y datos de transferencia
      allow read: if true;
      // Solo personal firmado puede cambiar la configuración
      allow write: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isTesorero();
      allow create: if isSignedIn() || true;
    }

    match /cedulas/{cedulaId} {
      // Se permite lectura pública para el auto-completado por C.I.
      allow read: if true;
      // Solo el script de importación o admin puede escribir
      allow write: if true; 
    }

    match /qr_transactions/{txId} {
      allow read, write: if isSignedIn();
    }
  }
}